{
  "name": "slopmuter-users-ms",
  "version": "0.1.0",
  "description": "User management microservice for SlopMuter, a browser extension that filters AI-generated slop and low-effort content from X/Twitter feeds.",
  "main": "dist/server.js",
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.prod.json",
    "start": "node dist/server.js",
    "docker:start": "docker compose up --build -d",
    "docker:stop": "docker compose down",
    "dev": "tsx --watch src/server.ts",
    "db:shell": "docker exec -it slopmuter-postgres psql -U postgres -d slopmuter",
    "redis:shell": "docker exec -it slopmuter-redis redis-cli",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Dirag Biswas (https://github.com/diragb)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diragb/slopmuter-users-ms.git"
  },
  "bugs": {
    "url": "https://github.com/diragb/slopmuter-users-ms/issues"
  },
  "homepage": "https://github.com/diragb/slopmuter-users-ms#readme",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/client-sqs": "^3.1024.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "rate-limit-redis": "^4.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/cors": "^2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9",
    "@types/lodash": "^4",
    "@types/node": "^25.5.0",
    "@types/pg": "^8",
    "@types/supertest": "^7",
    "@vitest/ui": "^4.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.13",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.13.0"
}
